{
  "name": "@ai-dialog/gateway",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "ai-dialog-gateway": "./dist/cli.js"
  },
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx --watch src/index.ts",
    "start": "node --env-file=../../.env dist/index.js",
    "connector": "node dist/cli.js",
    "connector:dev": "node --import tsx src/cli.ts",
    "pack:publish": "tsc -p tsconfig.json && node scripts/make-pkg.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-dialog/shared": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": "^0.3.168",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
