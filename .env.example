# --- Шлюз (gateway) ---
# Порт WS/HTTP сервера шлюза
GATEWAY_PORT=8787
# Хост для биндинга (в локальной разработке оставить 127.0.0.1)
GATEWAY_HOST=127.0.0.1

# Ключ Anthropic API — нужен и для Claude Code (Agent SDK), и для dashboard-адаптера
ANTHROPIC_API_KEY=sk-ant-...

# Путь к конфигу проектов (реестр: project -> endpoint + репозиторий + токен)
# По умолчанию packages/gateway/projects.json
PROJECTS_CONFIG=

# --- opencode-адаптер (опционально) ---
# Базовый URL запущенного opencode в server-режиме
OPENCODE_BASE_URL=http://127.0.0.1:4096

# --- carono-channel адаптер (мост на channel-дашборд claude.carono.ru) ---
# Базовый URL дашборда для машинных вызовов BridgeController
DASHBOARD_BASE_URL=https://claude.carono.site
# Bearer-секрет дашборда (из /home/carono/.claude/channels/dashboard/.env)
DASHBOARD_SECRET=
