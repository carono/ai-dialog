{
  "name": "ai-dialog",
  "version": "0.1.0",
  "private": true,
  "description": "Встраиваемый виджет диалога с AI: контекст текущей страницы уходит в настраиваемый эндпоинт (Claude Code, opencode, дашборд)",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:gateway": "pnpm --filter @ai-dialog/gateway dev",
    "dev:widget": "pnpm --filter @ai-dialog/widget dev",
    "build:shared": "pnpm --filter @ai-dialog/shared build",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0"
}
